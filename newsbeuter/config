## newsbeuter configuration
#
browser "qutebrowser %u"
#browser "[[ -n \"$( pgrep qutebrowser )\"  ]] && qutebrowser %u || w3m -M %u &> /dev/null "
#html-renderer "w3m -dump -T text/html"

auto-reload yes #si a 'yes', newsbeuter recharge vos flux à son démarrage
reload-time 15 #recharge vos flux toutes les n minutes, ici n = 15
notify-always no
#notify-format "newsbeuter: %n articles non lus parmis %f flux"
notify-format "newsbeuter: %n articles"
#notify-program "/usr/bin/notify-send --icon=feed-subscribe"
notify-program "/usr/bin/notify-send"
#notify-program "/home/jerome/.scripts/notify_news.sh"

bind-key SPACE open #Un exemple de raccourcis possible sur les commande interne de newsbeuter avec la touche SPACE
show-read-feeds no
show-read-articles no

articlelist-format "%4i %f %D  %?T?|%-17T| ?%t"
#feedlist-format     "%4i %n %11u %t"
#feedlist-format     "%n %11u %t"
feedlist-format     "%n %11u %T"
feed-sort-order firsttag


