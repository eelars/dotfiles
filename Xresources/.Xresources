! vim: ft=xdefaults
!#include ".Xresources.d/breezie"

!fonts
Xft.dpi: 96
*font: xft:M+1mn:size=12
*barFont: xft:M+1mn:size=12
*iconFont: xft:FontAwesome:size=12

!cursor
URxvt*cursorBlink: false
URxvt*cursorUnderline: false
Xcursor.theme: breeze

!font rendering
Xft.antialias: true
Xft.autohint: false
Xft.hinting: true
Xft.hintstyle: hintfull
Xft.lcdfilter: none
Xft.rgba: rgba

URxvt.scrollBar: false
URxvt.font:xft:Inconsolata:bold:size=10
URxvt*keysym.Home: \033[1~
URxvt*keysym.End: \033[4~

URxvt.url-launcher: /usr/bin/qutebrowser
URxvt.matcher.button: 1

!extensions
!URxvt.perl-ext-common: default,matcher,clipboard,resize-font

!notifications messages
URxvt*iso14755: False

! shortcuts
! clipboard
URxvt.keysym.Shift-Control-C: perl:clipboard:copy
URxvt.keysym.Shift-Control-V: perl:clipboard:paste
! resize-font
URxvt.keysym.C-minus:     resize-font:smaller
URxvt.keysym.C-equal:      resize-font:bigger
URxvt.keysym.C-plus:     resize-font:reset
URxvt.keysym.C-question:  resize-font:show

! breeze - terminal colours based on the KDE Breeze palette

URxvt*foreground:   #fcfcfc
URxvt*background:   #232629
!URxvt*cursorColor:  #d1b217
URxvt*cursorColor:  #ffffff


! black
URxvt*color0:       #31363b
URxvt*color8:       #4d4d4d

! red
URxvt*color1:       #ed2929
URxvt*color9:       #ed1515

!green
URxvt*color2:       #21d96d
URxvt*color10:      #0bd961

!yellow
URxvt*color3:       #fcc74c
URxvt*color11:      #fde04b

!blue
URxvt*color4:       #3daee9
URxvt*color12:      #3d95e9

!magenta
URxvt*color5:       #9847b5
URxvt*color13:      #a94fc9

!cyan
URxvt*color6:       #1abc9c
URxvt*color14:      #1cdc9a

!white
URxvt*color7:       #eff0f1
URxvt*color15:      #fcfcfc

