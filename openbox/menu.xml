<?xml version="1.0" encoding="UTF-8"?>
<openbox_menu xmlns="http://openbox.org/3.4/menu">
<menu id="system-menu" label="system">
  <item label="Openbox Configuration Manager">
    <action name="Execute">
      <command>obconf</command>
      <startupnotify><enabled>yes</enabled></startupnotify>
    </action>
  </item>
  <item label="Kde System Settings">
    <action name="Execute">
      <command>systemsettings5</command>
      <startupnotify><enabled>yes</enabled></startupnotify>
    </action>
  </item>
  <separator />
  <item label="Reconfigure Openbox">
    <action name="Reconfigure" />
  </item>
</menu>

<menu id="leave-menu" label="power">
  <item label="Lock">
    <action name="Execute">
      <command>slock</command>
    </action>
  </item>
  <item label="Log Out">
    <action name="Exit">
      <prompt>yes</prompt>
    </action>
  </item>
  <item label="Reboot">
    <action name="Execute">
        <prompt>Are you sure?</prompt>
        <command>systemctl reboot</command>
    </action>
  </item>
  <item label="Shutdown">
    <action name="Execute">
        <prompt>Are you sure?</prompt>
        <command>systemctl poweroff</command>
    </action>
  </item>
</menu>

<menu id="root-menu" label="Openbox 3">
  <item label="term">
    <action name="Execute">
      <command>urxvtc</command>
    </action>
  </item>
  <item label="dolphin">
    <action name="Execute">
      <command>dolphin</command>
    </action>
  </item>
  <item label="qutebrowser">
    <action name="Execute">
      <command>qutebrowser</command>
    </action>
  </item>

  <separator />
  <menu id="system-menu"/>
  <separator />
  <menu id="leave-menu"/>

</menu>

</openbox_menu>
